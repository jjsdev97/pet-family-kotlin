<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.2">
    <persistence-unit name="kotlin-prac" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>domain.human.Person</class>
        <class>domain.animal.BaseAnimal</class>
        <class>domain.animal.dog.Dog</class>
        <class>domain.animal.dog.Retriever</class>
        <class>domain.animal.dog.Poodle</class>
        <class>domain.animal.dog.Bulldog</class>
        <class>domain.animal.cat.Cat</class>
        <class>domain.animal.cat.StreetCat</class>
        <class>domain.animal.cat.PersianCat</class>
        <class>domain.animal.cat.SiameseCat</class>
        <class>domain.animal.mix.MixedDog</class>
        <class>domain.animal.mix.MixedCat</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:kotlin-prac;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

    <persistence-unit name="kotlin-prac-test" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>domain.human.Person</class>
        <class>domain.animal.BaseAnimal</class>
        <class>domain.animal.dog.Dog</class>
        <class>domain.animal.dog.Retriever</class>
        <class>domain.animal.dog.Poodle</class>
        <class>domain.animal.dog.Bulldog</class>
        <class>domain.animal.cat.Cat</class>
        <class>domain.animal.cat.StreetCat</class>
        <class>domain.animal.cat.PersianCat</class>
        <class>domain.animal.cat.SiameseCat</class>
        <class>domain.animal.mix.MixedDog</class>
        <class>domain.animal.mix.MixedCat</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:kotlin-prac-test;DB_CLOSE_DELAY=0"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
